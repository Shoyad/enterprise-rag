# Copy to .env and adjust.
# Retrieval runs locally with NO keys. Generated answers require a real provider key.

# --- Database ---
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
DATABASE_URL=postgresql+asyncpg://rag:rag@db:5432/rag

# --- Redis / background jobs ---
REDIS_URL=redis://redis:6379/0

# --- Embeddings (local, keyless) ---
# fastembed (local, default) | openai
EMBEDDINGS_PROVIDER=fastembed
EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5

# --- Generation (real providers only; no fake fallback) ---
# Leave GENERATION_PROVIDER empty to run ingestion + retrieval without answers.
# Set to "openai" or "anthropic" AND provide the matching key to enable answers.
GENERATION_PROVIDER=
GENERATION_MODEL=gpt-4o-mini
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Retrieval / chunking ---
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
RETRIEVAL_TOP_K=5

# --- App ---
LOG_LEVEL=INFO
